{
  "name": "agent-harness-action",
  "version": "1.1.0",
  "description": "CloudNua Agent Harness — wrap AI coding agents with pre/post policy scanning and governance guardrails.",
  "license": "MIT",
  "author": "CloudNua Ltd.",
  "homepage": "https://github.com/cloudnua/agent-harness-action#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/cloudnua/agent-harness-action.git"
  },
  "bugs": {
    "url": "https://github.com/cloudnua/agent-harness-action/issues"
  },
  "keywords": [
    "github-action",
    "actions",
    "ai-agents",
    "policy",
    "security",
    "scanning",
    "cloudnua"
  ],
  "scripts": {
    "build": "bun run build:pre && bun run build:main && bun run build:post && bun run verify:bundle",
    "build:pre": "ncc build src/pre.ts -o dist/pre --minify",
    "build:main": "ncc build src/main.ts -o dist/main --minify",
    "build:post": "ncc build src/post.ts -o dist/post --minify",
    "verify:bundle": "bash scripts/verify-bundle.sh",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@actions/core": "^1.11.0",
    "@actions/exec": "^1.1.1",
    "@actions/github": "^6.0.0"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.0.0",
    "@vercel/ncc": "^0.38.0",
    "js-yaml": "^4.1.1",
    "typescript": "^5.5.0",
    "vitest": "^3.2.0"
  }
}
